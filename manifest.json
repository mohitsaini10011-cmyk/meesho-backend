{
  "manifest_version": 3,
  "name": "Dyana Core AI Listing Studio",
  "version": "2.0",
  "description": "Dyana Core AI seller suite with listing generator, image optimizer, shipping optimizer, subscription and admin panel",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*",
    "https://supplier.meesho.com/*",
    "https://*.railway.app/*",
    "https://*.up.railway.app/*",
    "https://*.onrender.com/*",
    "https://meesho-backend-ga8x.onrender.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://supplier.meesho.com/*"
      ],
      "js": [
        "selector-utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "admin.html",
        "admin.js",
        "popup.html",
        "popup.js",
        "styles.css",
        "auth.html",
        "auth.js",
        "auth-styles.css",
        "auth-utils.js",
        "license-manager.js",
        "selector-utils.js",
        "content.js",
        "icons/icon16.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
